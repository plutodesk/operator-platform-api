# LOCAL: true  — 本地开发/CI：免 Google 登录，启用 /cms/v1/debug/login 多用户切换
# LOCAL: false — 生产/抽检：真实 Google OAuth，debug 路由不可用
LOCAL: true
DEBUG: true
PORT: 20010
MONGO_DB: operator_platform
REDIS_URL: redis://localhost:6379/6
REDIS_KWARGS: {"decode_responses": true}
MONGO_MAP:
  '': 'mongodb://localhost:27017'
  'operator_platform': 'mongodb://localhost:27017'

MONGO_URL: mongodb://localhost:27017
CDN_URL: https://jigsaw-cdn.plutodesk.com/
OAUTH_CLIENT_ID: your-google-oauth-client-id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET: your-google-oauth-client-secret
OAUTH_EMAIL_DOMAIN: your-company.com

APPLE_SUBSCRIPTION_KEY:
PUB_KEY:
APPLE_KEY_ID:
JWT_SECRET: change-me

# 加密 Token 凭证入库；Docker 部署时通过环境变量注入
CONFIG_ENCRYPTION_KEY: change-me-to-a-long-random-secret

GC_KEY: {}
BUCKET: plutodesk-jigsaw

# Google Ads / Unity 配置已迁移至 Admin「Token 配置」「广告平台配置」页面。
# 首次迁移可运行: python scripts/import_ads_config.py
