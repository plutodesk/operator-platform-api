# LOCAL: true  — 本地开发/CI：免 Google 登录，启用 /cms/v1/debug/login 多用户切换（Alice/Bob 协作冲突测试）
# LOCAL: false — 生产/抽检：真实 Google OAuth，debug 路由返回 404
LOCAL: true
DEBUG: true
PORT: 20010
MONGO_DB: operator_platform
REDIS_URL: redis://localhost:6379/6
REDIS_KWARGS: {"decode_responses": true}
MONGO_MAP:
  '': 'mongodb://localhost:27017'
  'operator_platform': 'mongodb://localhost:27017'

MONGO_URL: mongodb://localhost:27017
CDN_URL: https://jigsaw-cdn.plutodesk.com/
OAUTH_CLIENT_ID: your-google-oauth-client-id.apps.googleusercontent.com
OAUTH_EMAIL_DOMAIN: your-company.com

APPLE_SUBSCRIPTION_KEY:
PUB_KEY:
APPLE_KEY_ID:
JWT_SECRET: change-me

# Copy to conf.yaml and fill in secrets locally. Do not commit conf.yaml.
GOOGLE_ADS_CONFIG: {
  RefreshToken: your-google-ads-oauth-refresh-token,
  DeveloperToken: your-google-ads-developer-token,
  ClientSecret: your-google-oauth-client-secret,
  CustomerId: 8969851272,
  LoginCustomerId: ''
}
GC_KEY: {}
BUCKET: plutodesk-jigsaw
